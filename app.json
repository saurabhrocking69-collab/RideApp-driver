{
  "expo": {
    "name": "Sppero Buddy",
    "slug": "rideapp-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "versionCode": 10,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.saurabhspero.rideappdriver",
      "permissions": ["CAMERA", "RECEIVE_BOOT_COMPLETED", "VIBRATE", "POST_NOTIFICATIONS", "ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "ACCESS_BACKGROUND_LOCATION", "READ_EXTERNAL_STORAGE", "WAKE_LOCK", "FOREGROUND_SERVICE", "FOREGROUND_SERVICE_LOCATION", "FOREGROUND_SERVICE_CONNECTED_DEVICE"]
    },
       "config": {
      "googleMaps": {
        "apiKey": "AIzaSyAK3HFrZsahMLNVUFgxGAQMw_6OATDD8q4"
      }
    },
    "plugins": [
      ["@sentry/react-native/expo", { "uploadSourceMaps": false }],
      ["expo-notifications", {
        "icon": "./assets/icon.png",
        "color": "#e94560",
        "defaultChannel": "ride_requests",
        "mode": "production",
        "channels": [
          {
            "name": "ride_requests",
            "importance": 5,
            "bypassDnd": true,
            "sound": "default",
            "vibrationPattern": [0, 500, 150, 500, 150, 800],
            "lockscreenVisibility": 1
          },
          {
            "name": "default",
            "importance": 4,
            "sound": "default",
            "vibrationPattern": [0, 250, 250, 250],
            "lockscreenVisibility": 1
          },
          {
            "name": "driver_status",
            "importance": 2,
            "lockscreenVisibility": 1
          }
        ]
      }],
      ["expo-location", {
        "locationAlwaysAndWhenInUsePermission": "Ride tracking ke liye location chahiye",
        "locationAlwaysPermission": "Background mein bhi location chahiye taaki app minimize karne ke baad bhi aapki location update hoti rahe",
        "isIosBackgroundLocationEnabled": true,
        "isAndroidBackgroundLocationEnabled": true
      }],
      ["expo-image-picker", { "photosPermission": "Documents upload karne ke liye gallery access chahiye" }]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8c13e622-0206-4e3f-ad33-8851c0f9353c"
      }
    }
  }
}
